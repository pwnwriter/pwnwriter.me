<div
	class="prose-code:bg-b-code prose prose-custom max-w-none prose-headings:mt-10 prose-h2:text-lg prose-h3:text-base prose-h3:font-bold prose-h4:text-sm prose-h4:font-bold prose-a:italic prose-figcaption:mt-4 prose-figcaption:mb-8 prose-figcaption:text-xs prose-figcaption:uppercase prose-strong:text-f-high prose-code:rounded-md prose-code:py-1 prose-code:px-2 prose-code:font-normal prose-pre:rounded-xl prose-pre:text-base prose-img:rounded-xl"
>
	<slot />
</div>

<script>
	const icon = (d: string) =>
		`<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
	const copyIcon = icon('<rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>');
	const checkIcon = icon('<polyline points="20 6 9 17 4 12"/>');

	function addCopyButtons() {
		document.querySelectorAll<HTMLElement>('pre > code').forEach((code) => {
			const pre = code.parentElement!;
			if (pre.querySelector('.copy-btn')) return;

			const btn = Object.assign(document.createElement('button'), {
				className: 'copy-btn',
				ariaLabel: 'Copy code',
				innerHTML: copyIcon,
			});

			btn.addEventListener('click', () => {
				navigator.clipboard.writeText(code.textContent ?? '');
				btn.innerHTML = checkIcon;
				btn.classList.add('copied');
				setTimeout(() => { btn.innerHTML = copyIcon; btn.classList.remove('copied'); }, 1500);
			});

			pre.appendChild(btn);
		});
	}

	addCopyButtons();
	document.addEventListener('astro:after-swap', addCopyButtons);
</script>

<style>
	.prose :global(p) {
		@apply font-normal leading-[1.85] text-f-low;
	}

	.prose :global(a) {
		@apply italic underline decoration-f-low;
	}

	.prose :global(a:hover) {
		@apply no-underline;
	}

	.prose :global(blockquote) {
		@apply border-f-low;
	}

	.prose :global(blockquote > p) {
		@apply font-normal leading-[1.85] text-f-low;
	}

	.prose :global(blockquote > p::before),
	.prose :global(blockquote > p::after) {
		@apply hidden;
	}

	.prose :global(pre) {
		@apply relative mb-4 bg-b-med p-8 font-mono;
	}

	.prose :global(code) {
		@apply bg-b-high font-mono font-semibold;
	}

	.prose :global(code::before),
	.prose :global(code::after) {
		@apply hidden;
	}

	.prose :global(pre > code) {
		@apply bg-b-med p-0 text-sm leading-relaxed;
	}

	.prose :global(pre::before) {
		@apply absolute right-6 top-3 font-bold text-accent;
	}

	.prose :global(pre.language-javascript::before),
	.prose :global(pre.language-js::before) {
		content: 'js';
	}

	.prose :global(pre.language-html::before) {
		content: 'html';
	}

	.prose :global(pre.language-css::before) {
		content: 'css';
	}

	.prose :global(pre.language-typescript::before),
	.prose :global(pre.language-ts::before) {
		content: 'ts';
	}

	.prose :global(pre.language-svelte::before) {
		content: 'svelte';
	}

	.prose :global(.copy-btn) {
		@apply absolute top-3 right-3 flex items-center justify-center rounded-lg p-2 text-f-low opacity-0 transition-all duration-200;
		background: var(--b-high);
	}

	.prose :global(pre:hover .copy-btn) {
		@apply opacity-100;
	}

	.prose :global(.copy-btn:hover) {
		@apply text-accent;
	}

	.prose :global(.copy-btn.copied) {
		@apply text-accent opacity-100;
	}
</style>
