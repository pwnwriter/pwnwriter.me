---
import Layout from "~/layouts/Layout.astro";
import Wrapper from "~/components/wrapper.astro";
import Heading from "~/components/text/heading.astro";
import Lightbox from "~/components/lightbox.astro";

const LICENSE_URL = "https://creativecommons.org/licenses/by-nc-sa/4.0/";
const LICENSE_LABEL = "CC BY-NC-SA 4.0";

import { photos } from "~/pages/photos/photos";

// newest first
photos.sort((a, b) => (a.date < b.date ? 1 : -1));

// group by year (descending)
const grouped = new Map<string, typeof photos>();
for (const p of photos) {
  const arr = grouped.get(p.year) ?? [];
  arr.push(p);
  grouped.set(p.year, arr);
}
const years = [...grouped.keys()].sort((a, b) => b.localeCompare(a));

// global index for lightbox navigation
let globalIndex = 0;
---

<Layout title="photos" description="A small archive of my photos.">
  <Wrapper>
    <header class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <Heading Element="h1">Photos</Heading>
        <p class="mt-2 max-w-prose text-sm">
          A tiny archive of moments I like.
        </p>

        <p class="mt-3 text-xs">
          Licensed under{" "}
          <a
            href={LICENSE_URL}
            target="_blank"
            rel="noreferrer"
            class="underline decoration-[var(--f-low)]/20 underline-offset-4 hover:decoration-[var(--f-low)]/50"
          >
            {LICENSE_LABEL}
          </a>
          .
        </p>
      </div>
    </header>

    {years.map((year) => {
      const yearPhotos = grouped.get(year)!;
      return (
        <section class="mt-10">
          <h2 class="mb-4 text-sm font-medium tracking-wide text-f-low/50">{year}</h2>
          <div class="photo-masonry">
            {yearPhotos.map((p) => {
              const idx = globalIndex++;
              return (
                <figure class="photo-item" data-index={idx}>
                  <img
                    src={p.src}
                    alt={p.alt}
                    loading="lazy"
                    class="photo-img"
                  />
                  <figcaption class="photo-meta">
                    <span class="truncate">{p.alt}</span>
                    <span class="shrink-0 opacity-50">{p.date}</span>
                  </figcaption>
                </figure>
              );
            })}
          </div>
        </section>
      );
    })}

    {
      photos.length === 0 && (
        <p class="mt-6 text-sm" style="color: var(--f-low); opacity: 0.5;">not yet. soon.</p>
      )
    }
  </Wrapper>

  <Lightbox />
</Layout>

<style>
  /* Masonry via CSS columns */
  .photo-masonry {
    columns: 1;
    column-gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .photo-masonry {
      columns: 2;
    }
  }

  @media (min-width: 900px) {
    .photo-masonry {
      columns: 3;
    }
  }

  .photo-item {
    break-inside: avoid;
    margin-bottom: 0.75rem;
    cursor: pointer;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--f-low) 10%, transparent);
    background: color-mix(in srgb, var(--f-low) 3%, transparent);
    /* fade-in setup */
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }

  .photo-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .photo-img {
    width: 100%;
    display: block;
    transition: transform 0.3s ease;
  }

  .photo-item:hover .photo-img {
    transform: scale(1.03);
  }

  .photo-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.75rem;
    color: var(--f-low);
    opacity: 0.55;
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-item {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .photo-img {
      transition: none;
    }
  }
</style>

<script>
  function initScrollReveal() {
    const items = document.querySelectorAll<HTMLElement>(".photo-item");
    if (!items.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            // stagger based on position within its masonry container
            const siblings = el.parentElement?.querySelectorAll(".photo-item");
            const idx = siblings ? [...siblings].indexOf(el) : 0;
            el.style.transitionDelay = `${idx * 80}ms`;
            el.classList.add("visible");
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.1 },
    );

    items.forEach((item) => observer.observe(item));
  }

  document.addEventListener("DOMContentLoaded", initScrollReveal);
  if (document.readyState !== "loading") initScrollReveal();
</script>
