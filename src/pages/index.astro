---
import Layout from "~/layouts/Layout.astro";
import Wrapper from "~/components/wrapper.astro";
import Heading from "~/components/text/heading.astro";
import Subheading from "~/components/text/subheading.astro";
import Paragraph from "~/components/text/paragraph.astro";
import Link from "~/components/link.astro";
import PostList from "~/components/post-list.astro";
import "~/styles/index.css";
---

<Layout title="~" description="pwn::musings.">
  <Wrapper>
    <section class="hero">
      <div class="avatar-wrap">
        <img src="https://avatars.githubusercontent.com/u/90331517?s=400&u=69e445f801cc183e3657c7890b3178987577c5fa&v=4" alt="pwnwriter" />
      </div>
      <div>
        <h1 class="handwritten">
          Hi! I am <span class="shimmer">Nabeen</span>
        </h1>
        <Paragraph>
          I'm a cybersecurity student based in Miami, Florida.
        </Paragraph>
        <Paragraph>
          This space is more like a digital workbench, where I share thoughts,
          tinker with ideas, and write about the things I <a href="https://github.com/pwnwriter" target="_blank" rel="noopener noreferrer">enjoy</a>.
        </Paragraph>
      </div>
    </section>

    <div class="divider"></div>

    <section class="section">
      <!-- <Subheading Element="h2">Notes</Subheading> -->
      <PostList max={3} />
      <Link href="/notes">{"{ All notes }"}&nbsp;&nbsp;&Rarr;</Link>
    </section>
  </Wrapper>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    margin-bottom: 3.5rem;
  }

  @media (max-width: 640px) {
    .hero {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
  }

  .avatar-wrap {
    flex-shrink: 0;
    position: relative;
    padding: 0.35rem;
  }

  /* dashed accent ring that spins up on hover */
  .avatar-wrap::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px dashed color-mix(in srgb, var(--accent) 55%, transparent);
    animation: avatar-spin 18s linear infinite;
    animation-play-state: paused;
    transition: opacity 0.3s;
    opacity: 0.6;
  }

  .avatar-wrap:hover::before {
    animation-play-state: running;
    opacity: 1;
  }

  .avatar-wrap img {
    position: relative;
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid color-mix(in srgb, var(--f-low) 25%, transparent);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 40%, transparent);
    transition:
      border-color 0.3s,
      box-shadow 0.4s ease,
      transform 0.4s ease;
  }

  .avatar-wrap:hover img {
    border-color: var(--accent);
    box-shadow: 0 6px 22px -6px color-mix(in srgb, var(--accent) 55%, transparent);
    transform: scale(1.04) rotate(-2deg);
  }

  @keyframes avatar-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-wrap::before {
      animation: none;
    }
    .avatar-wrap:hover img {
      transform: none;
    }
  }

  .divider {
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--f-low) 25%, transparent),
      transparent
    );
    margin-bottom: 3rem;
  }

  .section {
    margin-bottom: 3rem;
  }

  .handwritten {
    font-family: "Caveat", cursive;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--f-high);
    margin-bottom: 1.5rem;
    transform: rotate(-0.5deg);
    letter-spacing: 0.02em;
  }

</style>
