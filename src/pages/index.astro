---
import Layout from "~/layouts/Layout.astro";
import Wrapper from "~/components/wrapper.astro";
import Heading from "~/components/text/heading.astro";
import Subheading from "~/components/text/subheading.astro";
import Paragraph from "~/components/text/paragraph.astro";
import Link from "~/components/link.astro";
import PostList from "~/components/post-list.astro";
import { projects } from "~/pages/projects/projects";
import "~/styles/index.css";

// lead with the first couple of projects (order set in projects.ts)
const featured = projects.slice(0, 2);
---

<Layout title="~" description="pwn::musings.">
  <Wrapper>
    <section class="hero">
      <div class="avatar-wrap">
        <img src="https://avatars.githubusercontent.com/u/90331517?s=400&u=69e445f801cc183e3657c7890b3178987577c5fa&v=4" alt="pwnwriter" />
      </div>
      <div>
        <h1 class="handwritten">
          Hi! I am <span class="shimmer">Nabeen</span>
        </h1>
        <Paragraph>
          I'm a cybersecurity student based in Miami, Florida.
        </Paragraph>
        <Paragraph>
          This space is more like a digital workbench, where I share thoughts,
          tinker with ideas, and write about the things I <a href="https://github.com/pwnwriter" target="_blank" rel="noopener noreferrer">enjoy</a>.
        </Paragraph>
      </div>
    </section>

    <div class="divider"></div>

    <section class="section">
      <!-- <Subheading Element="h2">Notes</Subheading> -->
      <PostList max={3} />
      <Link href="/notes">{"{ All notes }"}&nbsp;&nbsp;&Rarr;</Link>
    </section>

    {
      featured.length > 0 && (
        <>
          <div class="divider"></div>

          <section class="section">
            <span class="work-label">things i've built</span>
            <div class="work-grid mt-4 mb-4">
              {featured.map((p) => {
                const cover = p.cover ?? p.media[0];
                const isVideo = cover.kind === "video";
                const poster =
                  cover.kind === "image" ? cover.src : cover.poster;
                return (
                  <a href="/projects" class="work-card" aria-label={p.name}>
                    <span class="work-cover">
                      {isVideo ? (
                        <video
                          src={cover.src}
                          poster={poster ?? undefined}
                          muted
                          loop
                          playsinline
                          preload="none"
                        />
                      ) : (
                        poster && <img src={poster} alt={p.name} loading="lazy" />
                      )}
                    </span>
                    <span class="work-text">
                      <span class="work-name">{p.name}</span>
                      <span class="work-blurb">{p.blurb}</span>
                    </span>
                  </a>
                );
              })}
            </div>
            <Link href="/projects">{"{ All projects }"}&nbsp;&nbsp;&Rarr;</Link>
          </section>
        </>
      )
    }
  </Wrapper>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    margin-bottom: 3.5rem;
  }

  @media (max-width: 640px) {
    .hero {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
  }

  .avatar-wrap {
    flex-shrink: 0;
    position: relative;
    padding: 0.35rem;
  }

  /* dashed accent ring that spins up on hover */
  .avatar-wrap::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px dashed color-mix(in srgb, var(--accent) 55%, transparent);
    animation: avatar-spin 18s linear infinite;
    animation-play-state: paused;
    transition: opacity 0.3s;
    opacity: 0.6;
  }

  .avatar-wrap:hover::before {
    animation-play-state: running;
    opacity: 1;
  }

  .avatar-wrap img {
    position: relative;
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid color-mix(in srgb, var(--f-low) 25%, transparent);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 40%, transparent);
    transition:
      border-color 0.3s,
      box-shadow 0.4s ease,
      transform 0.4s ease;
  }

  .avatar-wrap:hover img {
    border-color: var(--accent);
    box-shadow: 0 6px 22px -6px color-mix(in srgb, var(--accent) 55%, transparent);
    transform: scale(1.04) rotate(-2deg);
  }

  @keyframes avatar-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-wrap::before {
      animation: none;
    }
    .avatar-wrap:hover img {
      transform: none;
    }
  }

  .divider {
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--f-low) 25%, transparent),
      transparent
    );
    margin-bottom: 3rem;
  }

  .section {
    margin-bottom: 3rem;
  }

  .work-label {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--f-low) 55%, transparent);
  }

  /* ---- Desktop: visual cards with a video cover ---- */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    text-decoration: none;
    transition: transform 0.25s ease;
  }

  .work-card:hover {
    transform: translateY(-3px);
  }

  .work-cover {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--f-low) 12%, transparent);
    /* gradient placeholder shows behind a missing / not-yet-loaded video */
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent) 20%, transparent),
      color-mix(in srgb, var(--f-low) 8%, transparent)
    );
  }

  .work-cover img,
  .work-cover video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .work-card:hover .work-cover {
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
  }

  .work-card:hover .work-cover img,
  .work-card:hover .work-cover video {
    transform: scale(1.05);
  }

  .work-name {
    font-size: 0.8rem;
    color: var(--f-low);
    transition: color 0.25s ease;
  }

  .work-card:hover .work-name {
    color: var(--accent);
  }

  /* description only surfaces on mobile */
  .work-blurb {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card,
    .work-cover img,
    .work-cover video {
      transition: none;
    }
    .work-card:hover {
      transform: none;
    }
  }

  /* ---- Mobile: show each project's clip full-width, stacked one per row.
     Videos autoplay when scrolled into view (no hover on touch). ---- */
  @media (max-width: 600px) {
    .work-grid {
      display: flex;
      flex-direction: column;
      grid-template-columns: none;
      gap: 2.25rem;
      counter-reset: work;
    }

    .work-card {
      display: block;
      transform: none;
    }

    .work-card:hover {
      transform: none;
    }

    /* keep the media visible on mobile (full width) */
    .work-cover {
      border-radius: 12px;
    }

    /* faint 01 / 02 / 03 eyebrow above each name */
    .work-text {
      display: block;
      margin-top: 0.65rem;
    }

    .work-text::before {
      counter-increment: work;
      content: counter(work, decimal-leading-zero);
      display: block;
      margin-bottom: 0.2rem;
      font-family: var(--font-mono, monospace);
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      color: color-mix(in srgb, var(--f-low) 45%, transparent);
    }

    .work-name {
      display: block;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--f-high);
    }

    .work-blurb {
      display: block;
      margin-top: 0.3rem;
      font-size: 0.82rem;
      line-height: 1.55;
      color: var(--f-low);
    }
  }

  .handwritten {
    font-family: "Caveat", cursive;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--f-high);
    margin-bottom: 1.5rem;
    transform: rotate(-0.5deg);
    letter-spacing: 0.02em;
  }

</style>

<script>
  const isMobile = () => window.matchMedia("(max-width: 600px)").matches;
  const reduceMotion = () =>
    window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Desktop: play a project's video cover on hover, reset on leave.
  function initWorkHover() {
    if (isMobile()) return;
    document
      .querySelectorAll<HTMLVideoElement>(".work-card video")
      .forEach((vid) => {
        const card = vid.closest(".work-card");
        if (!card) return;
        card.addEventListener("mouseenter", () => {
          vid.play().catch(() => {});
        });
        card.addEventListener("mouseleave", () => {
          vid.pause();
          vid.currentTime = 0;
        });
      });
  }

  // Mobile: no hover, so autoplay each clip while it's on screen and pause it
  // when it scrolls away (so we're never decoding off-screen video).
  function initWorkAutoplay() {
    if (!isMobile() || reduceMotion()) return;
    const vids = document.querySelectorAll<HTMLVideoElement>(".work-card video");
    if (!vids.length) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const v = entry.target as HTMLVideoElement;
          if (entry.isIntersecting) v.play().catch(() => {});
          else v.pause();
        });
      },
      { threshold: 0.4 },
    );

    vids.forEach((v) => io.observe(v));
  }

  function initWork() {
    initWorkHover();
    initWorkAutoplay();
  }

  document.addEventListener("DOMContentLoaded", initWork);
  if (document.readyState !== "loading") initWork();
</script>
